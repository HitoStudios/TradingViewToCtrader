# cTrader Open API credentials (from https://openapi.ctrader.com/apps)
CLIENT_ID=your_client_id
CLIENT_SECRET=your_client_secret

# OAuth access token & refresh token
# To get these:
#   1. Go to https://openapi.ctrader.com/apps -> Edit your app
#   2. Add "https://httpbin.org/anything" as a Redirect URI -> Save
#   3. Open in browser:
#      https://openapi.ctrader.com/apps/auth?client_id=YOUR_CLIENT_ID&redirect_uri=https://httpbin.org/anything&response_type=code&scope=trading
#   4. After authorizing, you'll land on httpbin. Copy the "code" from the URL.
#   5. Run in PowerShell:
#      $body = "grant_type=authorization_code&code=THE_CODE&redirect_uri=https://httpbin.org/anything&client_id=YOUR_CLIENT_ID&client_secret=YOUR_CLIENT_SECRET"
#      Invoke-RestMethod -Uri "https://openapi.ctrader.com/apps/token" -Method POST -Body $body -ContentType "application/x-www-form-urlencoded"
ACCESS_TOKEN=your_access_token
REFRESH_TOKEN=your_refresh_token

# cTrader account ID (numeric, from cTrader platform)
CTID_TRADER_ACCOUNT_ID=12345678

# Use "demo.ctraderapi.com" for demo accounts, "live.ctraderapi.com" for live
CTRADER_HOST=demo.ctraderapi.com

# Port for the webhook HTTP server (default 3000)
PORT=3000

# Webhook auth token - protects your endpoint from unauthorized alerts
WEBHOOK_SECRET=my_secret_token